class Solution {
    public int maximumWealth(int[][] accounts) {
        int maxWealth=0;
        for(int i=0;i<accounts.length;i++){
            int[] arr=accounts[i];
            int sum=0;
            for(int j=0;j<arr.length;j++){
                sum+=arr[j];
            }
            if(sum>maxWealth)
                maxWealth=sum;
        }
        return maxWealth;
    }
}
